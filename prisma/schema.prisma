generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                  @id @default("")
  email                  String                  @unique
  fullName               String                  @map("full_name")
  passwordHash           String?                 @map("password_hash")
  avatarUrl              String?                 @map("avatar_url")
  phone                  String?
  bio                    String?
  location               String?
  phoneVerified          Boolean                 @default(false) @map("phone_verified")
  emailVerified          Boolean                 @default(false) @map("email_verified")
  status                 UserStatus              @default(PENDING_VERIFICATION)
  timezone               String                  @default("Africa/Lagos")
  language               String                  @default("en")
  twoFactorEnabled       Boolean                 @default(false) @map("two_factor_enabled")
  twoFactorSecret        String?                 @map("two_factor_secret")
  twoFactorBackupCodes   String?                 @map("two_factor_backup_codes")
  googleId               String?                 @unique @map("google_id")
  githubId               String?                 @unique @map("github_id")
  notifyEmail            Boolean                 @default(true) @map("notify_email")
  notifySms              Boolean                 @default(false) @map("notify_sms")
  lastLoginAt            DateTime?               @map("last_login_at")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  role                   UserRole                @default(USER)
  notificationPreference NotificationPreference?
  notifications          Notification[]
  refreshTokens          RefreshToken[]
  sessions               UserSession[]
  workspaceMembers       WorkspaceMember[]

  @@map("users")
}

model UserSession {
  id           String   @id @default("")
  userId       String   @map("user_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  deviceInfo   Json?    @map("device_info")
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model RefreshToken {
  id        String   @id @default("")
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String    @id @default("")
  email     String    @unique
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  Verified  Boolean   @default(false) @map("verified")

  @@index([email])
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default("")
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@map("password_resets")
}

model Workspace {
  id                     String                    @id @default("")
  name                   String
  description            String?
  email                  String?                   @unique
  slug                   String                    @unique
  logoUrl                String?                   @map("logo_url")
  industry               String?
  website                String?
  subscriberLimit        Int                       @default(100)
  emailLimit             Int                       @default(20)
  fileLimit              Int                       @default(1)
  smsLimit               Int                       @default(0)
  otpLimit               Int                       @default(10)
  currentSubscribers     Int                       @default(0) @map("current_subscribers")
  currentEmailsSent      Int                       @default(0) @map("current_emails_sent")
  currentFilesUsed       Float                     @default(0) @map("current_files_used")
  currentSmsSent         Int                       @default(0) @map("current_sms_sent")
  currentOtpSent         Int                       @default(0) @map("current_otp_sent")
  teamSize               String?                   @map("team_size")
  timezone               String                    @default("Africa/Lagos")
  isActive               Boolean                   @default(true) @map("is_active")
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")
  plan                   SubscriptionTier          @default(FREE)
  planSubscriptionStatus PlanSubscriptionStatus    @default(INACTIVE)
  apiLimit               Int                       @default(100)
  autoTopUpAmount        Decimal                   @default(0) @map("auto_top_up_amount") @db.Decimal(12, 2)
  autoTopUpEnabled       Boolean                   @default(false) @map("auto_top_up_enabled")
  autoTopUpThreshold     Decimal                   @default(0) @map("auto_top_up_threshold") @db.Decimal(12, 2)
  blogLimit              Int                       @default(2)
  currentApiCalls        Int                       @default(0) @map("current_api_calls")
  currentBlogsCount      Int                       @default(0) @map("current_blogs_count")
  currentPushSent        Int                       @default(0) @map("current_push_sent")
  gracePeriodUntil       DateTime?                 @map("grace_period_until")
  pushLimit              Int                       @default(100)
  apiKeys                ApiKey[]
  blogPosts              BlogPost[]
  emailSenders           EmailSender?
  emailTemplates         EmailTemplate[]
  emails                 Email[]
  files                  File[]
  folders                Folder[]
  invoices               Invoice[]
  newsletters            Newsletter[]
  otpRequests            OtpRequest[]
  redemptions            PromoRedemption[]
  pushDevices            PushDevice[]
  pushNotifications      PushNotification[]
  senderIds              SenderId?
  smsMessages            SmsMessage[]
  subscribers            Subscriber[]
  planSubscriptions      SubscriptionTransaction[]
  usageLogs              UsageLog[]
  monthlyUsages          MonthlyUsage[]
  wallet                 Wallet?
  webhooks               Webhook[]
  alerts                 WorkspaceAlert[]
  members                WorkspaceMember[]
  subscription           WorkspaceSubscription?

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default("")
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(DEVELOPER)
  invitedBy   String?       @map("invited_by")
  joinedAt    DateTime?     @map("joined_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model TeamInvitation {
  id          String        @id @default("")
  workspaceId String        @map("workspace_id")
  email       String
  status      String        @default("PENDING")
  role        WorkspaceRole @default(DEVELOPER)
  token       String        @unique
  invitedBy   String        @map("invited_by")
  expiresAt   DateTime      @map("expires_at")
  acceptedAt  DateTime?     @map("accepted_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([email])
  @@map("team_invitations")
}

model ApiKey {
  id              String            @id @default("")
  workspaceId     String            @map("workspace_id")
  name            String
  key             String            @unique @map("key")
  jwt             String
  isTest          Boolean           @default(false)
  keyPrefix       String            @map("key_prefix")
  lastFourChars   String            @map("last_four_chars")
  status          ApiKeyStatus      @default(ACTIVE)
  permissions     Json?
  rateLimitPerMin Int               @default(100) @map("rate_limit_per_min")
  usageCount      Int               @default(0) @map("usage_count")
  lastUsedAt      DateTime?         @map("last_used_at")
  expiresAt       DateTime?         @map("expires_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  creditCap       Int?              @map("credit_cap")
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  apiusageLogs    APiUsageSummary[]

  @@index([workspaceId])
  @@map("api_keys")
}

model SenderId {
  id              String         @id @default("")
  workspaceId     String         @unique @map("workspace_id")
  senderId        String         @map("sender_id")
  status          SenderIdStatus @default(PENDING)
  rejectionReason String?        @map("rejection_reason")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  smsMessages     SmsMessage[]

  @@unique([workspaceId, senderId])
  @@map("sender_ids")
}

model EmailSender {
  id             String      @id @default("")
  workspaceId    String      @unique @map("workspace_id")
  email          String
  name           String
  verified       Boolean     @default(false)
  spfVerified    Boolean     @default(false) @map("spf_verified")
  dkimVerified   Boolean     @default(false) @map("dkim_verified")
  verifiedAt     DateTime?   @map("verified_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  domainVerified Boolean     @default(false) @map("domain_verified")
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  emails         Email[]
  otps           SenderOTP[]

  @@unique([workspaceId, email])
  @@map("email_senders")
}

model SenderOTP {
  id            String      @id @default("")
  emailSenderId String      @map("email_sender_id")
  code          String
  expiresAt     DateTime    @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  emailSender   EmailSender @relation(fields: [emailSenderId], references: [id], onDelete: Cascade)

  @@index([emailSenderId])
  @@map("sender_otps")
}

model SmsMessage {
  id          String    @id @default("")
  workspaceId String    @map("workspace_id")
  senderIdId  String?   @map("sender_id_id")
  recipient   String
  message     String
  units       Int       @default(1)
  creditsUsed Decimal   @map("credits_used") @db.Decimal(10, 2)
  status      SmsStatus @default(PENDING)
  providerRef String?   @map("provider_ref")
  deliveredAt DateTime? @map("delivered_at")
  scheduledAt DateTime? @map("scheduled_at")
  metadata    Json?
  source      String    @default("dashboard")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  senderId    SenderId? @relation(fields: [senderIdId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([recipient])
  @@index([status])
  @@index([createdAt])
  @@map("sms_messages")
}

model SmsBulkJob {
  id          String    @id @default("")
  workspaceId String    @map("workspace_id")
  name        String?
  totalCount  Int       @map("total_count")
  sentCount   Int       @default(0) @map("sent_count")
  failedCount Int       @default(0) @map("failed_count")
  status      String    @default("PENDING")
  scheduledAt DateTime? @map("scheduled_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([workspaceId])
  @@map("sms_bulk_jobs")
}

model Email {
  id             String               @id @default("")
  workspaceId    String               @map("workspace_id")
  emailSenderId  String?              @map("email_sender_id")
  campaignId     String?              @map("campaign_id")
  templateId     String?              @map("template_id")
  fromEmail      String               @map("from_email")
  fromName       String?              @map("from_name")
  toEmails       String[]             @map("to_emails")
  ccEmails       String[]             @default([]) @map("cc_emails")
  bccEmails      String[]             @default([]) @map("bcc_emails")
  subject        String
  bodyHtml       String?              @map("body_html")
  bodyText       String?              @map("body_text")
  attachments    Json?
  status         EmailStatus          @default(PENDING)
  providerRef    String?              @map("provider_ref")
  mailSentFrom   EmailFromType        @default(IN_APP)
  openedAt       DateTime?            @map("opened_at")
  clickedAt      DateTime?            @map("clicked_at")
  deliveredAt    DateTime?            @map("delivered_at")
  bouncedAt      DateTime?            @map("bounced_at")
  bounceReason   String?              @map("bounce_reason")
  scheduledAt    DateTime?            @map("scheduled_at")
  openCount      Int                  @default(0) @map("open_count")
  clickCount     Int                  @default(0) @map("click_count")
  metadata       Json?
  source         String               @default("dashboard")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  elements       EmailElement[]
  trackingEvents EmailTrackingEvent[]
  campaign       EmailCampaign?       @relation(fields: [campaignId], references: [id])
  emailSender    EmailSender?         @relation(fields: [emailSenderId], references: [id])
  template       EmailTemplate?       @relation(fields: [templateId], references: [id])
  workspace      Workspace            @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
  @@map("emails")
}

model EmailTemplate {
  id          String    @id @default("")
  workspaceId String    @map("workspace_id")
  name        String    @unique
  useCount    Int       @default(0) @map("use_count")
  subject     String
  bodyHtml    String?   @map("body_html")
  bodyText    String?   @map("body_text")
  variables   Json?
  elements    Json?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  emails      Email[]

  @@index([workspaceId])
  @@map("email_templates")
}

model EmailTrackingEvent {
  id        String   @id @default("")
  emailId   String   @map("email_id")
  event     String
  url       String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  country   String?
  createdAt DateTime @default(now()) @map("created_at")
  email     Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@map("email_tracking_events")
}

model EmailElement {
  id         String      @id @default("")
  emailId    String
  elementId  String
  type       ElementType
  content    String?
  properties Json
  sortOrder  Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  email      Email       @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@unique([emailId, elementId])
  @@index([emailId])
  @@index([type])
  @@index([sortOrder])
}

model EmailCampaign {
  id          String              @id @default("")
  workspaceId String              @map("workspace_id")
  status      EmailCampaignStatus @default(ACTIVE) @map("campaign_status")
  name        String              @unique @map("campaign_name")
  subject     String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  emailsSent  Int                 @default(0)
  openRate    Float?              @map("campaign_open_rate")
  clickRate   Float?              @map("campaign_click_rate")
  lastSentAt  DateTime?           @map("campaign_last_sent_at")
  emails      Email[]
}

model OtpRequest {
  id           String     @id @default("")
  workspaceId  String     @map("workspace_id")
  channel      OtpChannel
  recipient    String
  otpLength    Int        @default(6) @map("otp_length")
  template     String?
  validityMins Int        @default(10) @map("validity_mins")
  status       OtpStatus  @default(PENDING)
  attempts     Int        @default(0)
  maxAttempts  Int        @default(3) @map("max_attempts")
  verifiedAt   DateTime?  @map("verified_at")
  expiresAt    DateTime   @map("expires_at")
  providerRef  String?    @map("provider_ref")
  ipAddress    String?    @map("ip_address")
  metadata     Json?
  source       String     @default("api")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lastResentAt DateTime?
  otpEncrypted String     @map("otp_encrypted")
  resentCount  Int        @default(0)
  workspace    Workspace  @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([recipient])
  @@index([status])
  @@index([expiresAt])
  @@map("otp_requests")
}

model AuthOtp {
  id          String    @id @default("")
  email       String
  otpHash     String    @map("otp_hash")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  status      OtpStatus @default(PENDING)
  expiresAt   DateTime  @map("expires_at")
  verifiedAt  DateTime? @map("verified_at")
  ipAddress   String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@index([expiresAt])
  @@map("auth_otps")
}

model Folder {
  id          String    @id @default("")
  workspaceId String    @map("workspace_id")
  parentId    String?   @map("parent_id")
  name        String
  path        String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  files       File[]
  parent      Folder?   @relation("FolderChildren", fields: [parentId], references: [id])
  children    Folder[]  @relation("FolderChildren")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, path])
  @@index([workspaceId])
  @@map("folders")
}

model File {
  id             String         @id @default("")
  workspaceId    String         @map("workspace_id")
  folderId       String?        @map("folder_id")
  name           String
  originalName   String         @map("original_name")
  mimeType       String         @map("mime_type")
  size           Float
  storageKey     String         @unique @map("storage_key")
  cdnUrl         String?        @map("cdn_url")
  directUrl      String?        @map("direct_url")
  visibility     FileVisibility @default(PUBLIC)
  shareToken     String?        @unique @map("share_token")
  shareExpiresAt DateTime?      @map("share_expires_at")
  sharePassword  String?        @map("share_password")
  width          Int?
  height         Int?
  duration       Float?
  metadata       Json?
  source         String         @default("dashboard")
  uploadedBy     String?        @map("uploaded_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  folder         Folder?        @relation(fields: [folderId], references: [id])
  workspace      Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([folderId])
  @@index([mimeType])
  @@map("files")
}

model PushDevice {
  id          String       @id @default("")
  workspaceId String       @map("workspace_id")
  deviceToken String       @map("device_token")
  platform    PushPlatform
  appId       String?      @map("app_id")
  userId      String?      @map("user_id")
  segments    String[]     @default([])
  isActive    Boolean      @default(true) @map("is_active")
  lastSeenAt  DateTime?    @map("last_seen_at")
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, deviceToken])
  @@index([workspaceId])
  @@map("push_devices")
}

model PushNotification {
  id          String     @id @default("")
  workspaceId String     @map("workspace_id")
  title       String
  body        String
  imageUrl    String?    @map("image_url")
  data        Json?
  segments    String[]   @default([])
  platform    String[]   @default([])
  status      PushStatus @default(PENDING)
  totalSent   Int        @default(0) @map("total_sent")
  totalFailed Int        @default(0) @map("total_failed")
  creditsUsed Decimal    @map("credits_used") @db.Decimal(10, 2)
  scheduledAt DateTime?  @map("scheduled_at")
  sentAt      DateTime?  @map("sent_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@map("push_notifications")
}

model BlogPost {
  id          String         @id @default("")
  workspaceId String         @map("workspace_id")
  authorId    String         @map("author_id")
  title       String
  slug        String
  excerpt     String?
  content     String
  coverImage  String?        @map("cover_image")
  tags        String[]       @default([])
  seoTitle    String?        @map("seo_title")
  seoDesc     String?        @map("seo_desc")
  status      BlogPostStatus @default(DRAFT)
  publishedAt DateTime?      @map("published_at")
  scheduledAt DateTime?      @map("scheduled_at")
  viewCount   Int            @default(0) @map("view_count")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@map("blog_posts")
}

model Subscriber {
  id             String           @id @default("")
  workspaceId    String           @map("workspace_id")
  email          String
  name           String?
  status         SubscriberStatus @default(ACTIVE)
  segments       String[]         @default([])
  customFields   Json?            @map("custom_fields")
  confirmedAt    DateTime?        @map("confirmed_at")
  unsubscribedAt DateTime?        @map("unsubscribed_at")
  source         String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  workspace      Workspace        @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@map("subscribers")
}

model Newsletter {
  id          String           @id @default("")
  workspaceId String           @map("workspace_id")
  subject     String
  bodyHtml    String?          @map("body_html")
  bodyText    String?          @map("body_text")
  fromEmail   String           @map("from_email")
  fromName    String?          @map("from_name")
  segments    String[]         @default([])
  status      NewsletterStatus @default(DRAFT)
  totalSent   Int              @default(0) @map("total_sent")
  openCount   Int              @default(0) @map("open_count")
  clickCount  Int              @default(0) @map("click_count")
  bounceCount Int              @default(0) @map("bounce_count")
  unsubCount  Int              @default(0) @map("unsub_count")
  scheduledAt DateTime?        @map("scheduled_at")
  sentAt      DateTime?        @map("sent_at")
  creditsUsed Decimal          @default(0) @map("credits_used") @db.Decimal(10, 2)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@map("newsletters")
}

model Webhook {
  id              String            @id @default("")
  workspaceId     String            @map("workspace_id")
  name            String
  url             String
  secret          String
  events          WebhookEvent[]
  status          WebhookStatus     @default(ACTIVE)
  failureCount    Int               @default(0) @map("failure_count")
  lastTriggeredAt DateTime?         @map("last_triggered_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deliveryLogs    WebhookDelivery[]
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String       @id @default("")
  webhookId    String       @map("webhook_id")
  event        WebhookEvent
  payload      Json
  responseCode Int?         @map("response_code")
  responseBody String?      @map("response_body")
  duration     Int?
  success      Boolean      @default(false)
  attempt      Int          @default(1)
  nextRetryAt  DateTime?    @map("next_retry_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  webhook      Webhook      @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_deliveries")
}

model SubscriptionTransaction {
  id             String                      @id @default("")
  workspaceId    String                      @map("workspace_id")
  subscriptionId String                      @map("subscription_id")
  type           SubscriptionTransactionType @default(SUBSCRIPTION_PAYMENT)
  status         TransactionStatus           @default(PENDING)
  amount         Decimal                     @db.Decimal(12, 2)
  description    String
  referenceId    String?                     @map("reference_id")
  invoiceId      String?                     @map("invoice_id")
  metadata       Json?
  createdAt      DateTime                    @default(now()) @map("created_at")
  invoice        Invoice?                    @relation(fields: [invoiceId], references: [id])
  subscription   WorkspaceSubscription       @relation(fields: [subscriptionId], references: [id])
  workspace      Workspace                   @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([subscriptionId])
  @@index([createdAt])
  @@map("subscription_transactions")
}

model WorkspaceSubscription {
  id                 String                    @id @default("")
  workspaceId        String                    @unique @map("workspace_id")
  tier               SubscriptionTier          @default(FREE)
  status             SubscriptionStatus        @default(ACTIVE)
  monthlyPrice       Decimal                   @map("monthly_price") @db.Decimal(12, 2)
  currentPeriodStart DateTime                  @map("current_period_start")
  currentPeriodEnd   DateTime                  @map("current_period_end")
  cancelledAt        DateTime?                 @map("cancelled_at")
  paymentRef         String?                   @map("payment_ref")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  gracePeriodEnd     DateTime?                 @map("grace_period_end")
  planId             String?                   @map("plan_id")
  promoRedemptions   PromoRedemption[]
  planSubscriptions  SubscriptionTransaction[]
  plan               Plan?                     @relation(fields: [planId], references: [id])
  workspace          Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_subscriptions")
}

model Plan {
  id               String                  @id @default("")
  name             String                  @unique
  tier             SubscriptionTier
  description      String?
  price            Decimal                 @db.Decimal(12, 2)
  interval         String                  @default("month")
  emailCredits     Int                     @default(0) @map("email_credits")
  smsCredits       Int                     @default(0) @map("sms_credits")
  otpCredits       Int                     @default(0) @map("otp_credits")
  storageCredits   Float                   @default(0) @map("storage_credits")
  extraCreditRate  Decimal                 @default(0) @map("extra_credit_rate") @db.Decimal(12, 2)
  rollOverCredits  Boolean                 @default(false) @map("roll_over_credits")
  subscriberLimit  Int                     @default(100)
  emailLimit       Int                     @default(500)
  storageLimit     Float                   @default(100)
  smsLimit         Int                     @default(0)
  otpLimit         Int                     @default(0)
  blogLimit        Int                     @default(0)
  pushLimit        Int                     @default(0)
  apiLimit         Int                     @default(0)
  features         Json?
  isActive         Boolean                 @default(true)
  isArchived       Boolean                 @default(false) @map("is_archived")
  paystackPlanCode String?                 @map("paystack_plan_code")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  devApiAccess     Boolean                 @default(true)
  subscriptions    WorkspaceSubscription[]

  @@map("plans")
}

model Wallet {
  id             String    @id @default("")
  workspaceId    String    @unique @map("workspace_id")
  balance        Decimal   @default(0) @db.Decimal(12, 2)
  emailCredits   Int       @default(0) @map("email_credits")
  smsCredits     Int       @default(0) @map("sms_credits")
  otpCredits     Int       @default(0) @map("otp_credits")
  blogCredits    Int       @default(0) @map("blog_credits")
  pushCredits    Int       @default(0) @map("push_credits")
  apiCredits     Int       @default(0) @map("api_credits")
  storageCredits Float     @default(0) @map("storage_credits")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WorkspaceAlert {
  id            String    @id @default("")
  workspaceId   String    @map("workspace_id")
  title         String
  message       String
  type          String    @default("info")
  isDismissible Boolean   @default(true)
  dismissedAt   DateTime? @map("dismissed_at")
  linkUrl       String?   @map("link_url")
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("workspace_alerts")
}

model MonthlyUsage {
  id                 String    @id @default("")
  workspaceId        String    @map("workspace_id")
  service            Services
  month              String    @map("month") // format: YYYY-MM
  unitsUsed          Int       @default(0) @map("units_used")
  bundleLimit        Int       @default(0) @map("bundle_limit")
  topUpUnitsUsed     Int       @default(0) @map("top_up_units_used")
  topUpCost          Decimal   @default(0) @map("top_up_cost") @db.Decimal(12, 2)
  updatedAt          DateTime  @updatedAt @map("updated_at")
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, service, month])
  @@map("monthly_usages")
}

model UsageLog {
  id                 String    @id @default("")
  workspaceId        String    @map("workspace_id")
  service            String
  month              String    @map("month")
  currentSubscribers Int       @default(0) @map("current_subscribers")
  currentEmailsSent  Int       @default(0) @map("current_emails_sent")
  currentFilesUsed   Float     @default(0) @map("current_files_used")
  currentSmsSent     Int       @default(0) @map("current_sms_sent")
  currentOtpSent     Int       @default(0) @map("current_otp_sent")
  duration           Int?
  ipAddress          String?   @map("ip_address")
  userAgent          String?   @map("user_agent")
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  currentApiCalls    Int       @default(0) @map("current_api_calls")
  currentBlogsCount  Int       @default(0) @map("current_blogs_count")
  currentPushSent    Int       @default(0) @map("current_push_sent")
  workspace          Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([service])
  @@index([createdAt])
  @@map("usage_logs")
}

model APiUsageSummary {
  id           String   @id @default("")
  workspaceId  String   @map("workspace_id")
  apiKeyId     String?  @map("api_key_id")
  date         DateTime @db.Date
  service      String
  totalCalls   Int      @default(0) @map("total_calls")
  successCalls Int      @default(0) @map("success_calls")
  failedCalls  Int      @default(0) @map("failed_calls")
  apiKey       ApiKey?  @relation(fields: [apiKeyId], references: [id])

  @@unique([workspaceId, date, service])
  @@index([workspaceId])
  @@map("api_usage_summaries")
}

model PromoCode {
  id             String            @id @default("")
  code           String            @unique
  description    String?
  discountType   DiscountType      @default(PERCENTAGE)
  discountValue  Int?
  maxUses        Int?              @default(1)
  usedCount      Int               @default(0)
  validFrom      DateTime
  validUntil     DateTime
  minPlanTier    SubscriptionTier?
  appliesToPlans Json?
  firstTimeOnly  Boolean           @default(false)
  createdAt      DateTime          @default(now())
  bonusCredits   Int?              @map("bonus_credits")
  expiryDate     DateTime?         @map("expiry_date")
  flatDiscount   Decimal?          @map("flat_discount") @db.Decimal(12, 2)
  invoices       Invoice[]
  redemptions    PromoRedemption[]

  @@map("promo_codes")
}

model PromoRedemption {
  id             String                 @id @default("")
  promoCodeId    String                 @map("promo_code_id")
  workspaceId    String                 @map("workspace_id")
  subscriptionId String?                @map("subscription_id")
  invoiceId      String?                @map("invoice_id")
  discountAmount Int                    @map("discount_amount")
  createdAt      DateTime               @default(now())
  invoice        Invoice?               @relation(fields: [invoiceId], references: [id])
  promoCode      PromoCode              @relation(fields: [promoCodeId], references: [id])
  subscription   WorkspaceSubscription? @relation(fields: [subscriptionId], references: [id])
  workspace      Workspace              @relation(fields: [workspaceId], references: [id])

  @@map("promo_redemptions")
}

model Invoice {
  id                String                    @id @default("")
  workspaceId       String                    @map("workspace_id")
  invoiceNumber     String                    @unique @map("invoice_number")
  amount            Decimal                   @db.Decimal(12, 2)
  discount          Decimal?                  @default(0) @db.Decimal(12, 2)
  finalAmount       Decimal                   @db.Decimal(12, 2)
  currency          String                    @default("NGN")
  status            InvoiceStatus             @default(PENDING)
  paymentRef        String?                   @map("payment_ref")
  paymentMethod     String?                   @map("payment_method")
  paidAt            DateTime?                 @map("paid_at")
  periodStart       DateTime?                 @map("period_start")
  periodEnd         DateTime?                 @map("period_end")
  promoCodeId       String?                   @map("promo_code_id")
  metadata          Json?
  createdAt         DateTime                  @default(now())
  description       String?                   @map("description")
  billingEmail      String?                   @map("billing_email")
  items             InvoiceItem[]
  promoCode         PromoCode?                @relation(fields: [promoCodeId], references: [id])
  workspace         Workspace                 @relation(fields: [workspaceId], references: [id])
  redemptions       PromoRedemption[]
  planSubscriptions SubscriptionTransaction[]

  @@index([workspaceId])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default("")
  invoiceId   String   @map("invoice_id")
  description String
  amount      Decimal  @db.Decimal(12, 2)
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model TwoFactorOTP {
  email     String   @id
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
